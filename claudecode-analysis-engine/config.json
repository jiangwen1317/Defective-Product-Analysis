{
    "database": {
        "path": "emmc_analysis.db"
    },
    "monitor": {
        "directory": "./logs",
        "trigger_file": ".trigger",
        "scan_interval": 300,
        "extensions": [".txt", ".log"]
    },
    "parser": {
        "skip_sections": ["eMMC_EXT_CSD"],
        "encoding": "utf-8",
        "max_line_length": 10000
    },
    "export": {
        "output_dir": "./exports"
    }
}
